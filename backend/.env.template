# 公司法务智慧管理系统 - 环境配置
# 复制此文件为 .env 并修改对应值

# ===== 服务器配置 =====
PORT=3000
NODE_ENV=development

# ===== 数据库配置 (MySQL) =====
DATABASE_URL="mysql://root:password@localhost:3306/legal_management"
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=legal_management

# ===== Redis 配置 =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ===== JWT 配置 =====
JWT_SECRET=change-this-to-a-random-secret-key-at-least-32-chars
JWT_EXPIRES_IN=7d

# ===== AI Agent 配置 =====
AI_AGENT_ENABLED=true
OPENAI_API_KEY=
CLAUDE_API_KEY=

# ===== 文件上传配置 =====
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# ===== 日志配置 =====
LOG_LEVEL=info
LOG_DIR=./logs

# ===== CORS 配置 =====
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
